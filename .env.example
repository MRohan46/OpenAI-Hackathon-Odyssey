# Expo only exposes variables prefixed with EXPO_PUBLIC_ to mobile and web app code.
# Use your Supabase project URL and Publishable (or legacy anon) key. Never use a service_role key here.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
# Optional: required only when the deployed Dashboard function uses a different name.
# EXPO_PUBLIC_ROADMAP_FUNCTION_NAME=clever-service

# Never place GROQ_API_KEY, a Supabase service-role key, or any other secret in
# this file. Configure GROQ_API_KEY and GROQ_MODEL with `supabase secrets set`
# for the generate-roadmap Edge Function instead.
